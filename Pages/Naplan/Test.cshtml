@page "{index:int?}"
@model TestModel
@{
    ViewData["Title"] = $"Question {Model.CurrentPageIndex + 1}";
}

<div class="container py-4">
    <!-- Progress -->
    <div class="mb-4">
        <div class="d-flex justify-content-between small text-muted mb-1">
            <span>
                Question @Model.VisibleQuestionNumber of @Model.VisibleQuestionCount
                @if (string.IsNullOrEmpty(Model.CurrentPage.Type) || Model.CurrentPage.Type == "none")
                {
                    <span class="text-muted">(Reading passage)</span>
                }
            </span>
            <span>@((Model.VisibleQuestionNumber * 100.0 / Math.Max(Model.VisibleQuestionCount, 1)))% complete</span>
        </div>
        <div class="progress" style="height: 25px;">
            <div class="progress-bar progress-bar-striped bg-success"
                 style="width: @((Model.VisibleQuestionNumber * 100.0 / Math.Max(Model.VisibleQuestionCount, 1)))%">
            </div>
        </div>
    </div>

    <div class="mb-3 d-flex justify-content-between align-items-center">
        <div id="elapsedTime" class="fs-4 fw-bold text-primary">
            Elapsed: --:--
        </div>
        <div id="remainingTime" class="fs-4 fw-bold text-danger">
            Remaining: --:--
        </div>
    </div>

    <!-- Time-up overlay (hidden by default) -->
    <div id="timeUpOverlay" class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-75 d-none d-flex align-items-center justify-content-center" style="z-index: 2000;">
        <div class="bg-white p-5 rounded shadow-lg text-center">
            <h2 class="text-danger mb-4">Time's Up!</h2>
            <p class="fs-5 mb-4">Your test has been automatically submitted.</p>
            <button id="viewResultsBtn" class="btn btn-primary btn-lg px-5">OK – See Results</button>
        </div>
    </div>

    @if (Model.TotalPages == 0)
    {
        <div class="alert alert-warning">
            No test files found in <code>wwwroot/data/naplan</code><br>
            (Files must start with 'test' and end with '.json')
        </div>
    }
    else
    {
        <form method="post">
            <input type="hidden" asp-for="CurrentPageIndex"/>

            @if (Model.ParentIndex.HasValue)
            {
                <a asp-page="./Test" asp-route-index="@Model.ParentIndex"
                   class="btn btn-outline-info mb-3 d-block">
                    ← Back to main article
                </a>
            }

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white fs-4">
                    @Model.CurrentPage.Title
                </div>
                <div class="card-body p-5">
                    <p class="fs-3 fw-normal mb-4">@Model.CurrentPage.Content</p>

                    @if (!string.IsNullOrEmpty(Model.CurrentPage.ImageUrl))
                    {
                        <div class="text-center mb-4">
                            <img src="@Model.CurrentPage.ImageUrl"
                                 class="img-fluid rounded shadow"
                                 style="max-height: 380px; border: 8px solid #f0f0f0;"
                                 alt="Question illustration"/>
                        </div>
                    }

                    @if (string.IsNullOrEmpty(Model.CurrentPage.Type) || Model.CurrentPage.Type == "none")
                    {
                        <div class="alert alert-info mt-4 text-center">
                            <strong>Reading passage / Information</strong><br>
                            Please read the content above. No answer required on this page.
                            <br><br>
                            <small>Use Next to continue when ready.</small>
                        </div>
                    }
                    else
                    {
                        <div class="mt-4">
                            @if (Model.CurrentPage.Type == "single")
                            {
                                @for (var i = 0; i < Model.CurrentPage.Options.Count; i++)
                                {
                                    var opt = Model.CurrentPage.Options[i];
                                    <div class="form-check mb-3 p-3 border rounded bg-light">
                                        <input class="form-check-input" type="radio"
                                               id="opt_@i" name="SelectedAnswer" value="@opt"
                                               checked="@(Model.SelectedAnswer == opt)">
                                        <label class="form-check-label fs-4 w-100" for="opt_@i">
                                            @opt
                                        </label>
                                    </div>
                                }
                            }
                            else if (Model.CurrentPage.Type == "multi")
                            {
                                @for (var i = 0; i < Model.CurrentPage.Options.Count; i++)
                                {
                                    var opt = Model.CurrentPage.Options[i];
                                    <div class="form-check mb-3 p-3 border rounded bg-light">
                                        <input class="form-check-input" type="checkbox"
                                               id="opt_@i" name="SelectedMulti" value="@opt"
                                               checked="@(Model.SelectedMulti.Contains(opt))">
                                        <label class="form-check-label fs-4 w-100" for="opt_@i">
                                            @opt
                                        </label>
                                    </div>
                                }
                            }
                            else if (Model.CurrentPage.Type == "text")
                            {
                                <input type="text" asp-for="SelectedAnswer" class="form-control fs-3 p-3" placeholder="Type your answer here...">
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Navigation -->
            <div class="d-flex justify-content-between align-items-center">
                @if (Model.CurrentPageIndex > 0)
                {
                    <button type="submit" asp-page-handler="Prev"
                            class="btn btn-outline-secondary btn-lg px-5">
                        ← Previous
                    </button>
                }
                else
                {
                    <div></div>
                }

                @if (Model.CurrentPageIndex < Model.TotalPages - 1)
                {
                    <button type="submit" asp-page-handler="Next"
                            class="btn btn-primary btn-lg px-5">
                        Next →
                    </button>
                }
                else
                {
                    <button type="submit" asp-page-handler="Submit"
                            class="btn btn-success btn-lg px-5">
                        ✅ Submit Test
                    </button>
                }
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // DOM elements
            const elapsedDisplay   = document.getElementById('elapsedTime');
            const remainingDisplay = document.getElementById('remainingTime');
            const overlay          = document.getElementById('timeUpOverlay');
            const viewResultsBtn   = document.getElementById('viewResultsBtn');
            const form             = document.querySelector('form');

            // Server-passed values
            const forceReset         = '@(ViewData["ForceReset"]?.ToString() ?? "false")' === 'true';
            const serverStartTimeIso = '@(ViewData["StartTimeUtcIso"] ?? "")';
            const totalSeconds       = @(Model.TotalTimeSeconds ?? 0);
            const hasTimeLimit       = totalSeconds > 0;

            // Visibility of the remaining time
            if (!hasTimeLimit) {
                remainingDisplay.style.display = 'none';
            } else {
                remainingDisplay.style.display = 'block';  // or '' or 'inline-block'
            }

            // Initialize start time
            if (forceReset) {
                localStorage.removeItem('naplanTestStart');
            }

            let startMillis = serverStartTimeIso
                ? Date.parse(serverStartTimeIso)
                : Date.now();

            if (!serverStartTimeIso) {
                localStorage.setItem('naplanTestStart', new Date(startMillis).toISOString());
            }

            // Already timed out on load?
            if (hasTimeLimit && (Date.now() - startMillis) / 1000 >= totalSeconds) {
                showTimeUp(true); // true = already submitted or no need to submit
                return;
            }

            let isTimeUp = false;
            let submitInProgress = false;

            function formatTime(seconds) {
                const mins = Math.floor(seconds / 60);
                const secs = Math.floor(seconds % 60);
                return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            }

            function showTimeUp(alreadySubmitted = false) {
                overlay.classList.remove('d-none');
                document.querySelectorAll('input, button:not(#viewResultsBtn)').forEach(el => el.disabled = true);

                if (!alreadySubmitted && form) {
                    // Give user 1.5–2 seconds to read message before auto-submit
                    setTimeout(() => {
                        if (!submitInProgress) {
                            submitForm();
                        }
                    }, 3000);
                }
            }

            function submitForm() {
                if (!form || submitInProgress) return;

                console.log("Preparing manual fetch submit...");

                const formData = new FormData();

                // Manually add important fields
                formData.append('handler', 'Submit');
                formData.append('CurrentIndex', '@Model.CurrentPageIndex');

                // Add selected answer (last question)
                if ('@Model.CurrentPage.Type' === 'single' || '@Model.CurrentPage.Type' === 'text') {
                    formData.append('SelectedAnswer', document.querySelector('input[name="SelectedAnswer"]')?.value || '');
                } else if ('@Model.CurrentPage.Type' === 'multi') {
                    document.querySelectorAll('input[name="SelectedMulti"]:checked').forEach(cb => {
                        formData.append('SelectedMulti', cb.value);
                    });
                }

                // Add anti-forgery token manually if possible
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                if (tokenInput) {
                    formData.append('__RequestVerificationToken', tokenInput.value);
                }

                submitInProgress = true;

                fetch(window.location.href, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin'
                })
                .then(response => {
                    console.log("Server responded with:", response.status);
                    if (response.redirected) {
                        console.log("Redirecting to:", response.url);
                        window.location.href = response.url;
                    } else if (response.ok) {
                        window.location.href = '/Naplan/Results';
                    } else {
                        response.text().then(text => {
                            console.error("Server error response:", text);
                            //alert("Submission failed (status " + response.status + "). Going to results manually.");
                            window.location.href = '/Naplan/Results';
                        });
                    }
                })
                .catch(err => {
                    console.error("Fetch failed:", err);
                    window.location.href = '/Naplan/Results';
                });
            }

            function updateTimer() {
                if (isTimeUp || submitInProgress) return;

                const now = Date.now();
                const elapsedSeconds = Math.floor((now - startMillis) / 1000);

                elapsedDisplay.textContent = `Elapsed: ${formatTime(elapsedSeconds)}`;

                if (hasTimeLimit) {
                    const remaining = totalSeconds - elapsedSeconds;
                    remainingDisplay.textContent = `Remaining: ${formatTime(Math.max(remaining, 0))}`;
                    remainingDisplay.style.color = remaining < 60 ? '#dc3545' : '#198754';

                    if (remaining <= 0) {
                        isTimeUp = true;
                        showTimeUp();
                    }
                }
            }

            // Start timer
            updateTimer();
            const timerInterval = setInterval(updateTimer, 1000);

            // View Results button
            viewResultsBtn?.addEventListener('click', () => {
                window.location.href = '/Naplan/Results';
            });
        });
    </script>
}